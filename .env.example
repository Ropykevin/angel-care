FLASK_APP=run.py
FLASK_ENV=production
SECRET_KEY="pediatric-secret-key254!"
JWT_SECRET_KEY="pediatric-jwt-secret-key254!"

# Dedicated app user (created by: sudo bash mypostgresql.sh)
POSTGRES_USER=pediatric
POSTGRES_PASSWORD="Pediatric254!"
POSTGRES_DB=pediatric
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Local dev: localhost. Docker deploy builds URL in docker/entrypoint.sh from POSTGRES_*.
DATABASE_URL=postgresql://pediatric:Pediatric254!@localhost:5432/pediatric

APP_PORT=5052